<div class="lang-toggle" role="group" aria-label="Language focus">
  <button type="button" data-lang-btn="en">EN</button>
  <button type="button" data-lang-btn="ja">JA</button>
</div>

<script is:inline>
  (() => {
    const KEY = 'lang-focus';
    const root = document.documentElement;
    const saved = localStorage.getItem(KEY) || 'ja';
    root.dataset.lang = saved;

    const sync = () => {
      document.querySelectorAll('[data-lang-btn]').forEach((b) => {
        b.setAttribute('aria-pressed', b.dataset.langBtn === root.dataset.lang);
      });
    };
    sync();

    document.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-lang-btn]');
      if (!btn) return;
      root.dataset.lang = btn.dataset.langBtn;
      localStorage.setItem(KEY, btn.dataset.langBtn);
      sync();
    });
  })();
</script>

<style>
  .lang-toggle { display: inline-flex; gap: 4px; }
  .lang-toggle button {
    font: inherit;
    padding: 2px 10px;
    border: 1px solid #ccc;
    background: #fff;
    border-radius: 4px;
    cursor: pointer;
  }
  .lang-toggle button[aria-pressed="true"] {
    background: #111;
    color: #fff;
    border-color: #111;
  }
</style>
