<div class="lang-toggle" role="group" aria-label="Language focus">
  <button type="button" data-lang-btn="en">EN</button>
  <span class="lang-toggle__sep" aria-hidden="true">/</span>
  <button type="button" data-lang-btn="ja">JA</button>
</div>

<script is:inline>
  (() => {
    const KEY = 'lang-focus';
    const root = document.documentElement;
    const saved = localStorage.getItem(KEY) || 'all';
    root.dataset.lang = saved;

    const sync = () => {
      document.querySelectorAll('[data-lang-btn]').forEach((b) => {
        b.setAttribute('aria-pressed', b.dataset.langBtn === root.dataset.lang);
      });
    };
    sync();

    document.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-lang-btn]');
      if (!btn) return;
      root.dataset.lang = btn.dataset.langBtn;
      localStorage.setItem(KEY, btn.dataset.langBtn);
      sync();
    });
  })();
</script>

<style>
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .lang-toggle__sep { color: var(--ink-faint); }
  .lang-toggle button {
    font: inherit;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 2px 2px;
    border: none;
    background: transparent;
    color: var(--ink-faint);
    cursor: pointer;
    position: relative;
    transition: color 0.15s ease;
  }
  .lang-toggle button:hover { color: var(--ink); }
  .lang-toggle button[aria-pressed='true'] {
    color: var(--ink);
    background-image: linear-gradient(var(--marker), var(--marker));
    background-repeat: no-repeat;
    background-position: 0 75%;
    background-size: 100% 60%;
    padding: 2px 4px;
  }
</style>
