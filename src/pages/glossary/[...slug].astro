---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const glossaryEntries = await getCollection('glossary');
  return glossaryEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const base = import.meta.env.BASE_URL;
---
<BaseLayout title={entry.data.word} description={entry.data.definition}>
  <a class="back-link" href={`${base}#glossary`}>
    <span aria-hidden="true">←</span> back to glossary
  </a>
  <article class="article">
    <header class="article__head">
      <div class="article__meta mono">
        <span class="article__type">glossary · scrap</span>
        {entry.data.category && <span class="article__cat">{entry.data.category}</span>}
        <span class="article__sep">·</span>
        <time datetime={entry.data.date.toISOString()}>
          {entry.data.date.toISOString().slice(0, 10)}
        </time>
      </div>
      <h1>{entry.data.word}</h1>
      <p class="article__desc">{entry.data.definition}</p>
    </header>
    <hr class="article__rule" />
    <div class="article__body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex; align-items: center; gap: 6px;
    color: var(--ink-dim); text-decoration: none;
    font-family: var(--font-mono); font-size: 12px;
    margin-bottom: 32px;
    transition: color 0.15s ease, transform 0.15s ease;
  }
  .back-link:hover { color: var(--ink); transform: translateX(-2px); }

  .article__head { margin-bottom: 20px; }
  .article__meta {
    display: inline-flex; align-items: center; gap: 8px; flex-wrap: wrap;
    color: var(--ink-faint);
    margin-bottom: 12px;
  }
  .article__type {
    color: var(--margin);
    letter-spacing: 0.04em; text-transform: uppercase;
  }
  .article__cat {
    color: var(--ink);
    padding: 2px 8px; border: 1px solid var(--line);
    border-radius: 3px;
    letter-spacing: 0.04em; text-transform: uppercase; font-size: 10px;
  }
  .article__sep { opacity: 0.6; }
  .article__desc {
    color: var(--ink); font-family: var(--font-serif);
    font-style: italic; font-size: 1.2rem; line-height: 1.55;
    margin: 14px 0 0;
    padding: 10px 0 10px 14px;
    border-left: 3px solid var(--margin);
  }
  .article__rule {
    border: none; border-top: 1px dashed var(--line-strong);
    margin: 28px 0;
  }
  .article__body { font-size: 1rem; line-height: 1.8; }
</style>
