---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Washi from '../../components/bujo/Washi.astro';
import RulerLine from '../../components/bujo/RulerLine.astro';

export async function getStaticPaths() {
  const entries = await getCollection('scrap');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const base = import.meta.env.BASE_URL;
---
<BaseLayout title={entry.data.title} description={entry.data.description} active="scrap">
  <a class="back" href={`${base}scrap/`}><span aria-hidden="true">←</span> back to scrap wall</a>

  <article class="scrap-card">
    <Washi top={-14} left={40} w={100} rot={-5} color="#f4b94f" pattern="stripes" />
    <div class="kicker">◇ Scrap</div>
    <h1 class="title">{entry.data.title}</h1>
    <div class="sub">
      {entry.data.category && <span class="cat">#{entry.data.category.toLowerCase()}</span>}
      <time datetime={entry.data.date.toISOString()}>{entry.data.date.toISOString().slice(0, 10)}</time>
    </div>
    {entry.data.description && <p class="def">{entry.data.description}</p>}

    <div class="ruler-wrap"><RulerLine /></div>

    <div class="body">
      <Content />
    </div>
  </article>

  <p class="hint hand">
    scraps are short notes — importable into posts via <code>&lt;ScrapChip id="..." /&gt;</code>.
  </p>
</BaseLayout>

<style>
  .back {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-hand); font-size: 1.1rem;
    color: var(--ink); text-decoration: none;
    border-bottom: 1.5px dashed var(--ink);
    padding-bottom: 1px;
    margin-bottom: 24px;
  }
  .back:hover { color: var(--red); border-color: var(--red); }

  .scrap-card {
    position: relative;
    background: var(--paper-card);
    padding: 36px 42px 36px 56px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow:
      0 10px 22px rgba(42, 39, 34, 0.14),
      0 3px 5px rgba(42, 39, 34, 0.08);
    background-image: repeating-linear-gradient(
      180deg,
      transparent 0 30px,
      rgba(42, 107, 107, 0.13) 30px 31px
    );
    background-position: 0 42px;
  }
  .scrap-card::before {
    content: ''; position: absolute;
    left: 42px; top: 0; bottom: 0;
    width: 1px; background: rgba(184, 69, 45, 0.5);
  }

  .kicker {
    font-family: var(--font-hand); font-size: 1rem;
    color: var(--red); letter-spacing: 0.08em; text-transform: uppercase;
    margin-bottom: 4px;
  }
  .title {
    font-family: var(--font-marker); font-weight: 900;
    font-size: clamp(2rem, 4.2vw, 2.8rem);
    line-height: 1.05; letter-spacing: -0.015em;
    margin: 0 0 8px;
  }
  .sub {
    display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
    font-family: var(--font-hand); font-size: 1.05rem;
    color: var(--ink-dim);
    margin-bottom: 14px;
  }
  .cat { color: var(--teal); }
  .def {
    font-family: var(--font-marker);
    font-size: 1.3rem; line-height: 1.3;
    margin: 14px 0;
    color: var(--ink);
    padding: 0.2em 1em 0.2em 0.8em;
    border-left: 3px solid var(--red);
  }

  .ruler-wrap { margin: 18px 0 14px; }

  .body {
    font-family: var(--font-note);
    font-size: 1.08rem; line-height: 1.75;
  }
  .body :global(a) {
    color: var(--red); text-decoration: underline;
    text-underline-offset: 3px; text-decoration-thickness: 1.5px;
    text-decoration-style: dashed;
  }
  .body :global(p) { margin: 0 0 1em; }
  .body :global(code) {
    font-family: var(--font-mono); font-size: 0.88em;
    background: var(--paper-alt);
    padding: 0.1em 0.4em; border: 1px solid var(--line);
  }

  .hint {
    margin-top: 20px; color: var(--ink-dim);
    font-size: 1rem; text-align: center;
  }
  .hint code {
    font-family: var(--font-mono); font-size: 0.9em;
    background: var(--paper-alt);
    padding: 0.1em 0.4em; border: 1px solid var(--line);
  }
</style>
