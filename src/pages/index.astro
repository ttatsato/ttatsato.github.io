---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const glossary = (await getCollection('glossary')).sort((a, b) =>
  a.data.word.localeCompare(b.data.word)
);

// Curated selection of work shown on the landing page.
const selectedWork = [
  {
    title: 'Interview Matching Platform',
    period: '2024 — Now',
    role: 'Design · Frontend · Backend',
    stack: ['Next.js', 'NestJS', 'Redis', 'PostgreSQL', 'GCP'],
    summary:
      'Functional enhancement for a matching platform. Contributing across design, frontend, backend, and DB schema with ~20 members.',
    tape: 'mint',
  },
  {
    title: 'SES-Boost — In-house SaaS',
    period: '2023 — Now',
    role: 'Product Owner · Full-stack',
    stack: ['Next.js', 'Supabase', 'Rust / Axum', 'FastAPI', 'Elasticsearch'],
    summary:
      'Email ingestion → classification → matching. Migrated hot paths from Python to Rust to scale.',
    link: 'https://ses-boost.app/',
    tape: 'peach',
  },
  {
    title: 'BtoB Auction Site',
    period: '2024',
    role: 'Sales · Reqs · Dev',
    stack: ['Next.js', 'Supabase', 'FastAPI', 'Vercel'],
    summary:
      'Proposed a start-small approach, launched MVP with the client and early users, then rolled into full delivery.',
    tape: 'butter',
  },
  {
    title: 'Crypto Exchange Frontend Migration',
    period: '2023',
    role: 'Leader support · QA · Impl',
    stack: ['Vue', 'AngularJS', 'Rails', 'Playwright'],
    summary:
      'Zero-error, zero-bug replacement of a financial trading frontend from AngularJS to Vue.',
    tape: 'lav',
  },
  {
    title: 'Rust OSS — API Gateway',
    period: 'Ongoing',
    role: 'OSS maintainer',
    stack: ['Rust'],
    summary:
      'Designing and building an API Gateway in Rust as an open-source project.',
    tape: 'peach',
  },
  {
    title: 'Similar Paper Search Engine',
    period: '2018 — 2020',
    role: 'Design · Implementation',
    stack: ['Vue', 'Scala / Play 2', 'Python', 'Elasticsearch'],
    summary:
      'Research paper search on ES. Scraped PubMed / Scholar, built a similarity-based suggestion flow.',
    tape: 'mint',
  },
];

const groupedGlossary = glossary.reduce((acc, entry) => {
  const initialLetter = entry.data.word.charAt(0).toUpperCase();
  if (!acc[initialLetter]) acc[initialLetter] = [];
  acc[initialLetter].push(entry);
  return acc;
}, {} as Record<string, typeof glossary>);
const sortedLetters = Object.keys(groupedGlossary).sort();

const today = new Date().toISOString().slice(0, 10).replace(/-/g, '.');
---
<BaseLayout title="ttatsato — notes & work" variant="home" description="Portfolio and writing of ttatsato — engineer, founder, and occasional open-source author.">
  <!-- Hero / Journal entry -->
  <section class="hero">
    <div class="hero__inner">
      <div class="hero__date mono" data-reveal>
        <span>{today}</span>
        <span class="hero__date-sep">——</span>
        <span>entry no.01</span>
      </div>

      <h1 class="hero__title" data-reveal data-reveal-delay="1">
        Hi, I'm Tatsuya<span class="hero__dot">.</span><br />
        An engineer who likes
        <span class="mark">shipping</span>
        the unglamorous part.
      </h1>

      <p class="hero__lede" data-reveal data-reveal-delay="2">
        Around 10 years across the full product lifecycle — requirements, design,
        implementation, operations, and sales. Founder of ALBY Co., Ltd. Currently
        building an OSS API gateway in Rust and an in-house SaaS for SES providers.
      </p>

      <div class="hero__hand" data-reveal data-reveal-delay="3">
        <span class="hand">— this is a small, slow, hand-updated site.</span>
      </div>

      <div class="hero__cta" data-reveal data-reveal-delay="4">
        <a class="btn btn--primary" href="#work">See selected work →</a>
        <a class="btn btn--ghost" href="mailto:t-satoh@alby.co.jp">Say hi</a>
      </div>

      <ul class="hero__stats" data-reveal data-reveal-delay="4">
        <li><strong>10+</strong><span>years shipping</span></li>
        <li><strong>20+</strong><span>projects delivered</span></li>
        <li><strong>1</strong><span>company founded</span></li>
        <li><strong>∞</strong><span>curiosity</span></li>
      </ul>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="section">
    <div class="section__inner">
      <header class="section__head" data-reveal>
        <span class="section__idx">§ 01</span>
        <h2>About</h2>
        <span class="section__note hand">a quick note</span>
      </header>
      <div class="about-grid">
        <p class="about-lead" data-reveal>
          I care about shipping — the unglamorous part that happens after the demo.
          Across in-house products and client engagements I've handled everything from
          market validation to production ops, and I still enjoy writing code most.
        </p>
        <dl class="about-list" data-reveal data-reveal-delay="1">
          <div><dt>Founder</dt><dd>ALBY Co., Ltd. — CEO since 2018</dd></div>
          <div><dt>Focus</dt><dd>Product eng, DX, systems in Rust</dd></div>
          <div><dt>Certs</dt><dd>Java OCP Silver SE 8 · GCP GenAI Leader</dd></div>
          <div><dt>Based</dt><dd>Tokyo, Japan</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <!-- Work -->
  <section id="work" class="section">
    <div class="section__inner">
      <header class="section__head" data-reveal>
        <span class="section__idx">§ 02</span>
        <h2>Selected Work</h2>
        <a class="section__more" href={`${base}posts/project-history/`}>full history →</a>
      </header>
      <div class="work-grid">
        {selectedWork.map((w, i) => (
          <article class="work-card" data-reveal data-reveal-delay={String(((i % 3) + 1))}>
            <span class={`tape tape--${w.tape}`} aria-hidden="true">{w.period}</span>
            <div class="work-card__role mono">{w.role}</div>
            <h3 class="work-card__title">
              {w.link ? (
                <a href={w.link} target="_blank" rel="noopener noreferrer">
                  {w.title}
                  <span class="ext" aria-hidden="true">↗</span>
                </a>
              ) : (
                w.title
              )}
            </h3>
            <p class="work-card__summary">{w.summary}</p>
            <ul class="work-card__stack">
              {w.stack.map((s) => <li>{s}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Writing -->
  <section id="writing" class="section">
    <div class="section__inner">
      <header class="section__head" data-reveal>
        <span class="section__idx">§ 03</span>
        <h2>Writing</h2>
        <span class="section__note hand">{posts.length} {posts.length === 1 ? 'entry' : 'entries'} so far</span>
      </header>
      <ul class="post-list">
        {posts.map((post, i) => (
          <li data-reveal data-reveal-delay={String(((i % 3) + 1))}>
            <a href={`${base}posts/${post.id}/`}>
              <span class="post-list__date mono">{post.data.date.toISOString().slice(0, 10)}</span>
              <span class="post-list__title">{post.data.title}</span>
              <span class="post-list__arrow" aria-hidden="true">→</span>
              {post.data.description && (
                <span class="post-list__desc">{post.data.description}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Glossary -->
  <section id="glossary" class="section">
    <div class="section__inner">
      <header class="section__head" data-reveal>
        <span class="section__idx">§ 04</span>
        <h2>Glossary</h2>
        <span class="section__note hand">short notes — importable into articles</span>
      </header>
      <div class="glossary-wrap">
        {sortedLetters.map((letter) => (
          <div class="glossary-group" data-reveal>
            <div class="glossary-group__letter">{letter}</div>
            <ul class="glossary-group__list">
              {groupedGlossary[letter].map((entry) => (
                <li class="glossary-item">
                  <a href={`${base}glossary/${entry.id}/`}>
                    <div class="glossary-item__head">
                      <span class="glossary-item__word">{entry.data.word}</span>
                      {entry.data.category && <span class="glossary-item__cat mono">{entry.data.category}</span>}
                    </div>
                    <div class="glossary-item__def">{entry.data.definition}</div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section section--contact">
    <div class="section__inner">
      <div class="contact-card" data-reveal>
        <span class="section__idx">§ 05</span>
        <h2 class="contact-card__title">
          Have a problem worth <em>shipping</em>?
        </h2>
        <p class="contact-card__soft">
          Email is best for a first note — a paragraph is plenty.
        </p>
        <div class="contact-card__cta">
          <a class="btn btn--primary" href="mailto:t-satoh@alby.co.jp">t-satoh@alby.co.jp</a>
          <a class="btn btn--ghost" href="https://github.com/ttatsato" target="_blank" rel="noopener noreferrer">@ttatsato on GitHub →</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============ Hero ============ */
  .hero {
    position: relative;
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 72px 24px 56px;
  }
  .hero__inner { max-width: 760px; }

  .hero__date {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--ink-faint);
    padding-bottom: 6px;
    border-bottom: 1px dashed var(--line-strong);
  }
  .hero__date-sep { opacity: 0.6; }

  .hero__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(2rem, 5.2vw, 3.6rem);
    line-height: 1.14;
    letter-spacing: -0.02em;
    margin: 22px 0 22px;
    color: var(--ink);
  }
  .hero__dot { color: var(--margin); }

  .mark {
    position: relative;
    font-style: italic;
    padding: 0 0.1em;
    background-image: linear-gradient(var(--marker), var(--marker));
    background-repeat: no-repeat;
    background-position: 0 72%;
    background-size: 100% 48%;
  }

  .hero__lede {
    max-width: 640px;
    font-size: 1.1rem;
    line-height: 1.65;
    color: var(--ink-dim);
    margin: 0 0 16px;
  }

  .hand {
    font-family: var(--font-hand);
    font-size: 1.25rem;
    color: var(--margin);
    line-height: 1.2;
  }
  .hero__hand {
    margin: 6px 0 28px;
    transform: rotate(-0.8deg);
    padding-left: 4px;
  }

  .hero__cta { display: flex; flex-wrap: wrap; gap: 10px; }
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 18px; border-radius: 999px;
    font-family: var(--font-serif);
    font-weight: 500; font-size: 15px; letter-spacing: -0.005em;
    text-decoration: none;
    transition: background 0.18s var(--ease), color 0.18s var(--ease), border-color 0.18s var(--ease), transform 0.18s var(--ease);
  }
  .btn--primary {
    background: var(--ink); color: var(--paper);
    border: 1px solid var(--ink);
  }
  .btn--primary:hover { transform: translateY(-1px); }
  .btn--ghost {
    border: 1px solid var(--line-strong); color: var(--ink);
    background: transparent;
  }
  .btn--ghost:hover { border-color: var(--ink); }

  .hero__stats {
    list-style: none; padding: 18px 0 0; margin: 36px 0 0;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px;
    border-top: 1px solid var(--line);
  }
  .hero__stats li { display: flex; flex-direction: column; gap: 2px; }
  .hero__stats strong {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 2.4vw, 1.8rem);
    font-weight: 500; letter-spacing: -0.02em;
  }
  .hero__stats span { color: var(--ink-faint); font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.02em; }
  @media (max-width: 640px) { .hero__stats { grid-template-columns: repeat(2, 1fr); } }

  /* ============ Sections ============ */
  .section { padding: 64px 0; position: relative; }
  .section__inner { max-width: var(--maxw); margin: 0 auto; padding: 0 24px; }
  .section__head {
    display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap;
    padding-bottom: 16px; margin-bottom: 28px;
    border-bottom: 1px dashed var(--line-strong);
  }
  .section__idx {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-faint); letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .section__head h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    font-weight: 500; letter-spacing: -0.02em;
    margin: 0; color: var(--ink);
  }
  .section__note {
    margin-left: auto;
    transform: rotate(-1deg);
  }
  .section__more {
    margin-left: auto;
    color: var(--ink); text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--line-strong);
    font-size: 14px;
    transition: text-decoration-color 0.15s var(--ease);
  }
  .section__more:hover { text-decoration-color: var(--ink); }

  /* ============ About ============ */
  .about-grid {
    display: grid; grid-template-columns: 1.3fr 1fr; gap: 40px;
  }
  @media (max-width: 720px) { .about-grid { grid-template-columns: 1fr; gap: 24px; } }
  .about-lead {
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 1.9vw, 1.4rem);
    line-height: 1.55;
    color: var(--ink);
    margin: 0;
  }
  .about-list {
    margin: 0; padding: 0;
    display: grid; gap: 0;
  }
  .about-list > div {
    display: grid; grid-template-columns: 88px 1fr; gap: 16px;
    padding: 10px 0;
    border-bottom: 1px dashed var(--line);
  }
  .about-list dt {
    color: var(--ink-faint); font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.04em; text-transform: uppercase;
    padding-top: 2px;
  }
  .about-list dd {
    margin: 0; color: var(--ink); font-size: 15px;
  }

  /* ============ Work ============ */
  .work-grid {
    display: grid; gap: 28px 20px;
    grid-template-columns: repeat(3, 1fr);
  }
  @media (max-width: 960px) { .work-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .work-grid { grid-template-columns: 1fr; } }

  .work-card {
    position: relative;
    padding: 26px 22px 22px;
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    display: flex; flex-direction: column; gap: 12px;
    box-shadow: 0 1px 0 rgba(32, 35, 42, 0.04);
    transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
  }
  .work-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px -10px rgba(32, 35, 42, 0.18);
  }

  /* Washi tape label */
  .tape {
    position: absolute; top: -12px; left: 20px;
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink); padding: 4px 12px;
    letter-spacing: 0.04em;
    transform: rotate(-2.5deg);
    box-shadow: 0 1px 2px rgba(32, 35, 42, 0.08);
    border: 1px dashed rgba(32, 35, 42, 0.18);
    opacity: 0.95;
  }
  .tape--mint { background: var(--tape-mint); }
  .tape--peach { background: var(--tape-peach); }
  .tape--butter { background: var(--tape-butter); }
  .tape--lav { background: var(--tape-lav); }

  .work-card__role {
    color: var(--ink-faint); font-size: 11px;
    letter-spacing: 0.04em; text-transform: uppercase;
    margin-top: 4px;
  }
  .work-card__title {
    font-family: var(--font-serif);
    font-size: 1.2rem; font-weight: 500; letter-spacing: -0.01em;
    margin: 0; line-height: 1.3; color: var(--ink);
  }
  .work-card__title a {
    color: inherit; text-decoration: none;
    background-image: linear-gradient(var(--ink), var(--ink));
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 0% 1px;
    transition: background-size 0.25s var(--ease);
    padding-bottom: 2px;
  }
  .work-card__title a:hover { background-size: 100% 1px; }
  .work-card__title .ext { color: var(--ink-faint); font-size: 0.85em; margin-left: 4px; }
  .work-card__summary { color: var(--ink-dim); font-size: 15px; margin: 0; line-height: 1.6; flex-grow: 1; }
  .work-card__stack {
    list-style: none; padding: 0; margin: 6px 0 0;
    display: flex; flex-wrap: wrap; gap: 4px 10px;
  }
  .work-card__stack li {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-faint);
  }
  .work-card__stack li + li::before {
    content: '·'; margin-right: 10px; color: var(--ink-faint);
  }

  /* ============ Writing ============ */
  .post-list { list-style: none; padding: 0; margin: 0; }
  .post-list li { border-top: 1px solid var(--line); }
  .post-list li:last-child { border-bottom: 1px solid var(--line); }
  .post-list a {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    grid-template-areas: 'date title arrow' 'date desc arrow';
    gap: 2px 20px; align-items: baseline;
    padding: 18px 6px; text-decoration: none; color: var(--ink);
    transition: background 0.2s var(--ease), padding 0.2s var(--ease);
  }
  .post-list a:hover { background: var(--paper-2); padding-left: 14px; padding-right: 14px; }
  .post-list a:hover .post-list__arrow { transform: translateX(4px); }
  .post-list__date { grid-area: date; color: var(--ink-faint); align-self: center; }
  .post-list__title {
    grid-area: title;
    font-family: var(--font-serif);
    font-size: 1.15rem; font-weight: 500; letter-spacing: -0.01em;
  }
  .post-list__desc {
    grid-area: desc;
    color: var(--ink-dim); font-size: 14px; line-height: 1.5;
    margin-top: 2px;
  }
  .post-list__arrow {
    grid-area: arrow;
    color: var(--ink-faint); align-self: center;
    transition: transform 0.2s var(--ease), color 0.2s var(--ease);
  }
  .post-list a:hover .post-list__arrow { color: var(--ink); }
  @media (max-width: 640px) {
    .post-list a {
      grid-template-columns: 1fr auto;
      grid-template-areas: 'title arrow' 'date arrow' 'desc arrow';
    }
  }

  /* ============ Glossary ============ */
  .glossary-wrap { display: grid; gap: 28px; }
  .glossary-group {
    display: grid; grid-template-columns: 72px 1fr;
    gap: 20px; align-items: start;
  }
  @media (max-width: 640px) { .glossary-group { grid-template-columns: 1fr; gap: 8px; } }
  .glossary-group__letter {
    font-family: var(--font-serif);
    font-size: 2.4rem; font-weight: 500; letter-spacing: -0.02em;
    color: var(--ink-dim); line-height: 1;
    position: sticky; top: 80px;
    padding-top: 8px;
    border-top: 1px solid var(--line);
  }
  .glossary-group__list {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;
  }
  @media (max-width: 720px) { .glossary-group__list { grid-template-columns: 1fr; } }
  .glossary-item a {
    display: block; padding: 16px 18px;
    background: var(--paper-card);
    border: 1px solid var(--line); border-radius: var(--radius-sm);
    text-decoration: none; color: inherit;
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease), background 0.2s var(--ease);
  }
  .glossary-item a:hover {
    border-color: var(--line-strong);
    transform: translateY(-1px);
    background: #fff;
  }
  .glossary-item__head {
    display: flex; align-items: center; gap: 10px; margin-bottom: 4px;
  }
  .glossary-item__word {
    font-family: var(--font-serif);
    font-weight: 500; font-size: 1.1rem; color: var(--ink);
    letter-spacing: -0.01em;
  }
  .glossary-item__cat {
    font-size: 10px; color: var(--ink-faint);
    letter-spacing: 0.06em; text-transform: uppercase;
    padding: 2px 6px; border: 1px solid var(--line);
    border-radius: 3px;
  }
  .glossary-item__def {
    color: var(--ink-dim); font-size: 14px; line-height: 1.55;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ============ Contact ============ */
  .section--contact { padding-top: 24px; padding-bottom: 48px; }
  .contact-card {
    padding: 48px 40px;
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    max-width: 760px;
  }
  .contact-card__title {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3.4vw, 2.6rem);
    font-weight: 500; letter-spacing: -0.02em; line-height: 1.15;
    margin: 12px 0 10px; color: var(--ink);
  }
  .contact-card__title em {
    font-style: italic;
    position: relative;
    background-image: linear-gradient(var(--marker), var(--marker));
    background-repeat: no-repeat;
    background-position: 0 72%;
    background-size: 100% 46%;
    padding: 0 0.08em;
  }
  .contact-card__soft { color: var(--ink-dim); font-size: 1.02rem; margin: 0 0 24px; }
  .contact-card__cta { display: flex; flex-wrap: wrap; gap: 10px; }
</style>
