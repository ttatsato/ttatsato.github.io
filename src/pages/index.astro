---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Highlighter from '../components/bujo/Highlighter.astro';
import Bullet from '../components/bujo/Bullet.astro';
import Washi from '../components/bujo/Washi.astro';
import RulerLine from '../components/bujo/RulerLine.astro';
import SectionStamp from '../components/bujo/SectionStamp.astro';
import IndexCard from '../components/bujo/IndexCard.astro';
import { projects, certs } from '../data/projects';

const base = import.meta.env.BASE_URL;

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const scraps = (await getCollection('scrap')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const selectedProjects = projects.slice(0, 6);
const lead = posts[0];
const rest = posts.slice(1, 5);

const tags = ['All', 'Rust', 'TypeScript', 'Next.js', 'Python', 'PostgreSQL', 'Elasticsearch', 'GCP'];
const techChips = ['Rust', 'TypeScript', 'Next.js', 'Python', 'PostgreSQL', 'Elasticsearch', 'GCP'];
---
<BaseLayout title="ttatsato — a notebook" variant="home" active="home" description="Notebook & portfolio of ttatsato — engineer, founder at ALBY Co., Ltd.">

  <!-- =========================================================
       SPREAD: Profile (left) + Journal (right) — the main hero
       ========================================================= -->
  <section class="spread">
    <div class="spread__gutter" aria-hidden="true"></div>

    <!-- ===== LEFT PAGE: Profile ===== -->
    <div class="page page--left">
      <Washi top={30} left={16} w={160} rot={-4} color="#f4b94f" pattern="stripes" />
      <div class="kicker" data-reveal>page 01 &nbsp;·&nbsp; about</div>

      <h1 class="hello" data-reveal data-reveal-delay="1">
        Hello,<br />
        I'm <Highlighter color="pink">Tatsuya</Highlighter><span class="dot">.</span>
      </h1>
      <div class="tagline" data-reveal data-reveal-delay="2">
        engineer · founder · full-cycle shipper
      </div>

      <div class="ruler" data-reveal data-reveal-delay="2"><RulerLine /></div>

      <p class="intro" data-reveal data-reveal-delay="3">
        ~10 years shipping software end-to-end — from requirements and design through
        implementation, operations, and sales. Right now I'm the PO for an
        inbox-driven B2B SaaS, and writing an
        <Highlighter color="green">open-source API gateway in Rust</Highlighter>.
      </p>

      <ul class="bullets" data-reveal data-reveal-delay="4">
        <li><Bullet kind="star" color="var(--red)" />founder, <b>ALBY Co., Ltd.</b> — since 2018</li>
        <li><Bullet kind="dot" color="var(--teal)" />based in <b>Tokyo</b>, shipping remotely</li>
        <li><Bullet kind="dot" color="var(--teal)" />writing in english &amp; <span class="marker">日本語</span></li>
        <li><Bullet kind="open" color="var(--ink-dim)" />currently: rust · api gateway · oss</li>
      </ul>

      <ul class="tech" data-reveal data-reveal-delay="4">
        {techChips.map((s, i) => (
          <li style={`--rot:${(i % 2 === 0 ? -1 : 1) * 0.8}deg`}>#{s}</li>
        ))}
      </ul>

      <div class="certs" data-reveal>
        <SectionStamp label="CERTS" sub="credentials" rot={-3} />
        <ul class="certs__list">
          {certs.map((c) => (
            <li>
              <span class="chk" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 20 20">
                  <path d="M3 3 L 17 2 L 18 17 L 2 18 Z" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M5 10 L 9 14 L 16 5" stroke="var(--red)" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <span class="certs__date">{c.date}</span> — {c.label}
            </li>
          ))}
        </ul>
      </div>

      <div class="foot hand">
        <span>— about / 01 —</span>
        <span>turn the page →</span>
      </div>
    </div>

    <!-- ===== RIGHT PAGE: Journal ===== -->
    <div class="page page--right">
      <Washi top={30} right={16} w={160} rot={6} color="#a0c8b4" pattern="dots" />
      <div class="kicker kicker--right" data-reveal>journal &nbsp;·&nbsp; page 02</div>

      <h2 class="journal" data-reveal data-reveal-delay="1">
        <Highlighter color="yellow">Journal</Highlighter>
      </h2>
      <div class="tagline tagline--right" data-reveal data-reveal-delay="2">
        latest entries · writing &amp; scraps
      </div>

      <div class="ruler" data-reveal data-reveal-delay="2"><RulerLine /></div>

      {lead && (
        <a class="lead" href={`${base}posts/${lead.id}/`} data-reveal data-reveal-delay="3">
          <div class="lead__kicker">
            ★ latest · {lead.data.date.toISOString().slice(0, 10)}
          </div>
          <div class="lead__title">{lead.data.title}</div>
          {lead.data.description && (
            <div class="lead__excerpt">{lead.data.description}</div>
          )}
          {lead.data.tags && (
            <div class="lead__tags">
              {lead.data.tags.map((t) => <span>#{t}</span>)}
            </div>
          )}
        </a>
      )}

      <ul class="journal-list" data-reveal data-reveal-delay="4">
        {rest.map((p, i) => (
          <li>
            <a href={`${base}posts/${p.id}/`}>
              <Bullet kind="dot" color="var(--teal)" />
              <span class="num">#{String(posts.length - 1 - i).padStart(2, '0')}</span>
              <div class="meta">
                <div class="title">{p.data.title}</div>
                <div class="sub">{p.data.date.toISOString().slice(0, 10)}{p.data.kicker ? ` · ${p.data.kicker}` : ''}</div>
              </div>
              <span class="arrow">→</span>
            </a>
          </li>
        ))}
        {posts.length === 0 && <li class="empty">No posts yet.</li>}
      </ul>

      <div class="foot hand foot--right">
        <span>{posts.length} total</span>
        <span>see all entries →</span>
      </div>
    </div>
  </section>

  <!-- =========================================================
       Selected Work — project cards
       ========================================================= -->
  <section class="section" id="work">
    <div class="section__inner">
      <div class="section__head" data-reveal>
        <SectionStamp label="SELECTED WORK" sub="recent — jump to full history →" rot={-2} color="var(--navy)" />
        <a class="section__link hand" href={`${base}career/`}>full history →</a>
      </div>

      <div class="work-grid">
        {selectedProjects.map((p, i) => {
          const accent = ['var(--red)', 'var(--teal)', 'var(--navy)', 'var(--olive)'][i % 4];
          const tapeColor = ['#ff9b7a', '#a0c8b4', '#9bb0d6', '#d4d28a'][i % 4];
          const rot = (i % 2 === 0 ? -1.2 : 1.2);
          return (
            <article class="wcard" data-reveal data-reveal-delay={String(((i % 3) + 1))}
              style={`--accent:${accent}; transform:rotate(${rot}deg); box-shadow:5px 5px 0 ${accent};`}>
              <div class="wcard__tape"><Washi top={-12} left={20} w={80} rot={-5} color={tapeColor} pattern="stripes" /></div>
              <div class="wcard__head">
                <span class="wcard__num" style={`color:${accent}`}>#{p.num}</span>
                <span class="wcard__period">{p.period}</span>
              </div>
              <h3 class="wcard__title">
                {p.link ? (
                  <a href={p.link} target="_blank" rel="noopener noreferrer">{p.title} <span class="ext">↗</span></a>
                ) : (
                  p.title
                )}
              </h3>
              <div class="wcard__meta">
                {p.contract} · team of {p.team}
              </div>
              <div class="wcard__role">role: {p.role.join(' · ')}</div>
              <ul class="wcard__stack">
                {p.stack.slice(0, 8).map((s) => <li>{s}</li>)}
              </ul>
              {p.highlights && p.highlights.length > 0 && (
                <ul class="wcard__hl">
                  {p.highlights.slice(0, 2).map((h) => (
                    <li><Bullet kind="star" color={accent} />{h}</li>
                  ))}
                </ul>
              )}
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- =========================================================
       Scrap wall — teaser
       ========================================================= -->
  <section class="section section--scrap" id="scrap">
    <div class="section__inner">
      <div class="section__head" data-reveal>
        <SectionStamp label="SCRAPS" sub="short notes · importable into articles" rot={-2} color="var(--red)" />
        <a class="section__link hand" href={`${base}scrap/`}>wall of scraps →</a>
      </div>

      <div class="scrap-wall">
        {scraps.slice(0, 6).map((s, i) => {
          const rot = ((i * 37) % 10 - 5) * 0.5;
          const pin = ['var(--red)', 'var(--teal)', 'var(--navy)', 'var(--olive)'][i % 4];
          return (
            <div class="scrap-wall__item" data-reveal data-reveal-delay={String(((i % 3) + 1))} style={`transform:rotate(${rot}deg)`}>
              <span class="pin" style={`--pin:${pin}`}></span>
              <IndexCard
                title={s.data.title}
                sub={s.data.category}
                body={s.data.description}
                href={`${base}scrap/${s.id}/`}
                rot={0}
                width="100%"
              />
            </div>
          );
        })}
        {scraps.length === 0 && <div class="empty hand">Nothing pinned yet.</div>}
      </div>
    </div>
  </section>

  <!-- =========================================================
       Contact
       ========================================================= -->
  <section class="section section--contact" id="contact">
    <div class="section__inner contact">
      <div class="contact__tape"><Washi top={-14} left={30} w={160} rot={-4} color="#ff9b7a" pattern="stripes" /></div>
      <div data-reveal>
        <div class="hand" style="font-size:1.2rem;color:var(--red);">let's talk ↘</div>
        <h2 class="contact__h">
          Got a problem worth <Highlighter color="yellow">shipping</Highlighter>?
        </h2>
        <p class="contact__p">
          Email is best for a first note — a paragraph is plenty.
        </p>
        <div class="contact__cta">
          <a class="btn btn--ink" href="mailto:t-satoh@alby.co.jp">✎ t-satoh@alby.co.jp</a>
          <a class="btn btn--ghost" href="https://github.com/ttatsato" target="_blank" rel="noopener noreferrer">@ttatsato on github →</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* =========================================================
     Spread layout
     ========================================================= */
  .spread {
    max-width: var(--maxw);
    margin: 24px auto 0;
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 2.5px solid var(--ink);
    background: var(--paper);
    box-shadow: 6px 6px 0 var(--ink);
    margin-left: auto; margin-right: auto;
    overflow: hidden;
  }
  .spread__gutter {
    position: absolute; top: 0; bottom: 0; left: 50%;
    width: 44px; transform: translateX(-50%);
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.18) 0%,
      rgba(0, 0, 0, 0.04) 30%,
      rgba(0, 0, 0, 0.04) 70%,
      rgba(0, 0, 0, 0.18) 100%
    );
    pointer-events: none; z-index: 3;
  }
  @media (max-width: 900px) {
    .spread { grid-template-columns: 1fr; }
    .spread__gutter { display: none; }
    .spread .page--right { border-top: 2px dashed var(--ink); }
  }

  .page {
    position: relative;
    padding: 44px 44px 64px;
    min-height: 680px;
  }
  @media (max-width: 600px) {
    .page { padding: 34px 22px 60px; min-height: auto; }
  }

  .kicker {
    font-family: var(--font-hand);
    font-size: 17px; color: var(--ink-dim);
    margin-top: 14px;
  }
  .kicker--right { text-align: right; }

  .hello {
    font-family: var(--font-marker);
    font-weight: 900;
    font-size: clamp(3rem, 7vw, 5.6rem);
    line-height: 0.9;
    margin: 10px 0 10px;
    color: var(--ink);
    letter-spacing: -0.02em;
  }
  .hello .dot { color: var(--red); }

  .tagline {
    font-family: var(--font-hand);
    font-size: clamp(1.35rem, 2.2vw, 1.7rem);
    color: var(--teal);
    margin-bottom: 10px;
  }
  .tagline--right { text-align: right; color: var(--ink-dim); font-size: 1.2rem; }

  .ruler { margin: 10px 0; }

  .intro {
    font-family: var(--font-note);
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    line-height: 1.55;
    margin: 14px 0 18px;
    max-width: 540px;
  }

  .bullets {
    list-style: none; padding: 0; margin: 10px 0 16px;
    font-family: var(--font-note);
    font-size: 1.08rem; line-height: 1.9;
  }
  .bullets b { font-weight: 700; }

  .tech {
    list-style: none; padding: 0; margin: 16px 0 0;
    display: flex; flex-wrap: wrap; gap: 8px;
  }
  .tech li {
    font-family: var(--font-hand);
    font-size: 1.1rem;
    border: 2px solid var(--ink);
    background: var(--paper-card);
    padding: 2px 12px;
    transform: rotate(var(--rot));
    display: inline-block;
  }

  .certs { margin: 28px 0 0; }
  .certs__list {
    list-style: none; padding: 0; margin: 14px 0 0;
    font-family: var(--font-note); font-size: 1rem; line-height: 1.9;
  }
  .certs__list li { display: flex; align-items: baseline; gap: 8px; }
  .chk { color: var(--ink); display: inline-flex; }
  .certs__date { color: var(--ink-dim); }

  .foot {
    position: absolute; bottom: 22px; left: 44px; right: 44px;
    font-size: 18px; color: var(--ink-dim);
    display: flex; justify-content: space-between;
  }
  .foot--right { }

  /* ===== Right page: Journal ===== */
  .journal {
    font-family: var(--font-marker);
    font-weight: 900;
    font-size: clamp(2.6rem, 5.6vw, 4.2rem);
    line-height: 0.95;
    text-align: right;
    margin: 10px 0 2px;
  }

  .lead {
    display: block;
    background: var(--paper-card);
    border: 2.5px solid var(--ink);
    padding: 16px 18px;
    margin: 16px 0 16px;
    box-shadow: 4px 4px 0 var(--ink);
    color: var(--ink); text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .lead:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--ink); }
  .lead__kicker {
    font-family: var(--font-hand); font-size: 15px; color: var(--red);
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .lead__title {
    font-family: var(--font-marker); font-weight: 700;
    font-size: 1.6rem; line-height: 1.1; margin: 6px 0 8px;
  }
  .lead__excerpt {
    font-family: var(--font-note); font-size: 1rem; line-height: 1.45;
  }
  .lead__tags {
    display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px;
    font-family: var(--font-hand); font-size: 15px; color: var(--ink-dim);
  }

  .journal-list {
    list-style: none; padding: 0; margin: 0;
    font-family: var(--font-note);
  }
  .journal-list a {
    display: grid; grid-template-columns: 28px 56px 1fr 28px; gap: 10px;
    align-items: baseline; padding: 10px 2px;
    color: var(--ink); text-decoration: none;
    border-bottom: 1.5px dotted rgba(42, 39, 34, 0.2);
    transition: background 0.15s ease;
  }
  .journal-list a:hover { background: rgba(42, 39, 34, 0.04); }
  .journal-list a:hover .arrow { transform: translateX(4px); color: var(--red); }
  .journal-list .num { font-family: var(--font-marker); font-size: 1.3rem; color: var(--teal); }
  .journal-list .title { font-family: var(--font-marker); font-weight: 700; font-size: 1.12rem; line-height: 1.15; }
  .journal-list .sub { font-family: var(--font-hand); font-size: 0.95rem; color: var(--ink-dim); margin-top: 2px; }
  .journal-list .arrow {
    color: var(--ink-dim); transition: transform 0.2s ease, color 0.2s ease;
    justify-self: end; font-family: var(--font-marker);
  }
  .journal-list .empty { padding: 12px; color: var(--ink-dim); font-family: var(--font-hand); font-size: 1.2rem; }

  /* =========================================================
     Generic section
     ========================================================= */
  .section { padding: 56px 0 28px; position: relative; }
  .section__inner { max-width: var(--maxw); margin: 0 auto; padding: 0 24px; }
  .section__head {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
    margin-bottom: 30px;
  }
  .section__link {
    margin-left: auto;
    color: var(--ink); text-decoration: none;
    font-size: 1.25rem; border-bottom: 1.5px dashed var(--ink);
    padding-bottom: 1px;
  }
  .section__link:hover { color: var(--red); border-color: var(--red); }

  /* =========================================================
     Work cards
     ========================================================= */
  .work-grid {
    display: grid; gap: 28px 20px;
    grid-template-columns: repeat(2, 1fr);
  }
  @media (max-width: 760px) { .work-grid { grid-template-columns: 1fr; } }

  .wcard {
    position: relative;
    background: var(--paper-card);
    border: 2.5px solid var(--ink);
    padding: 22px 22px 18px;
    transition: transform 0.2s ease;
  }
  .wcard:hover { transform: rotate(0deg) translateY(-2px) !important; }
  .wcard__tape > * { }
  .wcard__head {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 4px;
  }
  .wcard__num {
    font-family: var(--font-marker);
    font-size: 2rem; font-weight: 700;
  }
  .wcard__period {
    font-family: var(--font-hand); font-size: 1rem; color: var(--ink-dim);
  }
  .wcard__title {
    font-family: var(--font-marker); font-weight: 700;
    font-size: 1.35rem; line-height: 1.1; margin: 0 0 8px;
  }
  .wcard__title a { color: inherit; text-decoration: none; border-bottom: 1.5px solid var(--ink); }
  .wcard__title a:hover { color: var(--red); border-color: var(--red); }
  .wcard__title .ext { font-size: 0.75em; color: var(--ink-dim); }
  .wcard__meta {
    font-family: var(--font-hand); font-size: 1rem; color: var(--ink-dim);
    margin-bottom: 2px;
  }
  .wcard__role {
    font-family: var(--font-hand); font-size: 1rem; color: var(--teal);
    margin-bottom: 10px;
  }
  .wcard__stack {
    list-style: none; padding: 0; margin: 0 0 10px;
    display: flex; flex-wrap: wrap; gap: 5px;
  }
  .wcard__stack li {
    font-family: var(--font-hand); font-size: 13px;
    border: 1.5px solid rgba(42, 39, 34, 0.4);
    padding: 1px 8px; background: var(--paper);
  }
  .wcard__hl {
    list-style: none; padding: 0; margin: 0;
    font-family: var(--font-note); font-size: 0.95rem; line-height: 1.45;
  }
  .wcard__hl li { margin: 3px 0; }

  /* =========================================================
     Scrap wall
     ========================================================= */
  .section--scrap { background: var(--paper-dark); padding-top: 56px; padding-bottom: 40px; border-top: 2px dashed var(--ink); border-bottom: 2px dashed var(--ink); }
  .scrap-wall {
    display: grid; gap: 22px;
    grid-template-columns: repeat(3, 1fr);
  }
  @media (max-width: 900px) { .scrap-wall { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .scrap-wall { grid-template-columns: 1fr; } }

  .scrap-wall__item {
    position: relative;
    transition: transform 0.2s ease;
  }
  .scrap-wall__item:hover { transform: translateY(-4px) !important; }
  .pin {
    position: absolute; top: -6px; left: 50%;
    transform: translateX(-50%);
    width: 14px; height: 14px; border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #fff, var(--pin) 60%, rgba(0, 0, 0, 0.6));
    box-shadow: 0 2px 3px rgba(0, 0, 0, 0.25);
    z-index: 3;
  }

  .empty { color: var(--ink-dim); font-size: 1.3rem; padding: 20px; }

  /* =========================================================
     Contact
     ========================================================= */
  .section--contact { padding-top: 32px; }
  .contact {
    position: relative;
    background: var(--paper-card);
    border: 2.5px solid var(--ink);
    padding: 44px 36px 40px;
    box-shadow: 5px 5px 0 var(--red);
    max-width: 820px;
  }
  .contact__h {
    font-family: var(--font-marker);
    font-weight: 800;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1; letter-spacing: -0.01em;
    margin: 6px 0 12px;
  }
  .contact__p {
    font-family: var(--font-note); font-size: 1.05rem; color: var(--ink-dim);
    margin: 0 0 24px;
  }
  .contact__cta { display: flex; flex-wrap: wrap; gap: 12px; }

  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 18px;
    font-family: var(--font-marker); font-weight: 700; font-size: 1rem;
    text-decoration: none;
    border: 2.5px solid var(--ink);
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease, color 0.15s ease;
    box-shadow: 3px 3px 0 var(--ink);
  }
  .btn--ink { background: var(--ink); color: var(--paper); }
  .btn--ink:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--ink); }
  .btn--ghost { background: var(--paper-card); color: var(--ink); }
  .btn--ghost:hover { background: var(--paper); transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--ink); }
</style>
