---
import LangToggle from '../components/LangToggle.astro';
interface Props {
  title: string;
  description?: string;
  variant?: 'home' | 'article';
}
const { title, description, variant = 'article' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light" />
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Caveat:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <title>{title}</title>
  </head>
  <body data-variant={variant}>
    <div class="paper" aria-hidden="true"></div>

    <header class="site-header">
      <div class="site-header__inner">
        <a href={base} class="brand">
          <span class="brand__mark" aria-hidden="true">✱</span>
          <span class="brand__name">ttatsato <span class="brand__sub">/ notes &amp; work</span></span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href={`${base}#work`}>Work</a>
          <a href={`${base}#writing`}>Writing</a>
          <a href={`${base}#scrap`}>Scrap</a>
          <a href={`${base}#contact`}>Contact</a>
        </nav>
        <LangToggle />
      </div>
    </header>

    <main class:list={['main', `main--${variant}`]}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__left mono">
          <span>© {new Date().getFullYear()} ttatsato</span>
          <span class="sep">·</span>
          <span>Tokyo, JP</span>
        </div>
        <div class="site-footer__links">
          <a href="https://github.com/ttatsato" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-in');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.08 }
        );
        const run = () =>
          document.querySelectorAll('[data-reveal]:not(.is-in)').forEach((el) => io.observe(el));
        run();
        document.addEventListener('astro:after-swap', run);
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Paper palette */
    --paper: #faf7f0;
    --paper-2: #f3ede0;
    --paper-card: #ffffff;
    --ink: #20232a;
    --ink-dim: #5a5f6b;
    --ink-faint: #8c909a;
    --line: #e6ddca;
    --line-strong: #cbbf9e;
    --rule: rgba(32, 35, 42, 0.06);
    --dot: rgba(32, 35, 42, 0.14);

    --margin: #c76d5e;      /* notebook margin red — used sparingly */
    --ink-link: #335aa6;     /* classic ink blue */
    --marker: #fff3a6;       /* soft yellow highlighter */
    --tape-mint: #c8e6d0;
    --tape-peach: #f6d1b7;
    --tape-butter: #f3e5a0;
    --tape-lav: #dcd4ec;

    --radius: 10px;
    --radius-sm: 6px;
    --maxw: 1100px;
    --maxw-read: 680px;

    --font-serif: 'Fraunces', 'Hiragino Mincho ProN', 'Yu Mincho', Georgia, serif;
    --font-hand: 'Caveat', 'Fraunces', cursive;
    --font-mono: 'JetBrains Mono', ui-monospace, Menlo, monospace;
    --font-sans: 'Fraunces', 'Hiragino Sans', 'Noto Sans JP', system-ui, sans-serif;

    --ease: cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-serif);
    font-optical-sizing: auto;
    font-variation-settings: 'SOFT' 60, 'WONK' 0;
    font-size: 17px;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
    min-height: 100vh;
  }

  ::selection { background: var(--marker); color: var(--ink); }

  /* ====== Paper backdrop (dot grid) ====== */
  .paper {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background-image: radial-gradient(var(--dot) 1px, transparent 1px);
    background-size: 22px 22px;
    background-position: 10px 10px;
    opacity: 0.55;
    mask-image: linear-gradient(180deg, transparent, #000 5%, #000 95%, transparent);
    -webkit-mask-image: linear-gradient(180deg, transparent, #000 5%, #000 95%, transparent);
  }

  /* ====== Header ====== */
  .site-header {
    position: sticky; top: 0; z-index: 40;
    background: rgba(250, 247, 240, 0.85);
    backdrop-filter: blur(8px) saturate(110%);
    -webkit-backdrop-filter: blur(8px) saturate(110%);
    border-bottom: 1px solid var(--line);
  }
  .site-header__inner {
    max-width: var(--maxw); margin: 0 auto;
    padding: 14px 22px;
    display: flex; align-items: center; gap: 16px;
  }
  .brand {
    display: inline-flex; align-items: baseline; gap: 8px;
    color: var(--ink); text-decoration: none;
    font-family: var(--font-serif);
    font-weight: 600; letter-spacing: -0.01em;
  }
  .brand__mark { color: var(--margin); font-size: 18px; transform: translateY(1px); }
  .brand__name { font-size: 17px; }
  .brand__sub {
    font-family: var(--font-hand);
    color: var(--ink-dim);
    font-weight: 400; font-size: 18px;
    margin-left: 4px;
  }
  .site-nav { display: flex; gap: 22px; margin-left: auto; }
  .site-nav a {
    color: var(--ink-dim); text-decoration: none;
    font-family: var(--font-serif); font-size: 15px;
    position: relative;
    transition: color 0.15s var(--ease);
  }
  .site-nav a::after {
    content: ''; position: absolute; left: 0; right: 0; bottom: -3px;
    height: 6px; background: var(--marker); border-radius: 2px;
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.25s var(--ease);
    z-index: -1;
  }
  .site-nav a:hover { color: var(--ink); }
  .site-nav a:hover::after { transform: scaleX(1); }

  @media (max-width: 760px) { .site-nav { display: none; } }

  /* ====== Main ====== */
  .main { position: relative; z-index: 1; }
  .main--article {
    max-width: var(--maxw-read); margin: 0 auto; padding: 56px 24px 96px;
  }
  .main--home { padding-bottom: 80px; }

  /* ====== Footer ====== */
  .site-footer {
    position: relative; z-index: 1;
    border-top: 1px solid var(--line);
    margin-top: 80px;
    background: var(--paper-2);
  }
  .site-footer__inner {
    max-width: var(--maxw); margin: 0 auto;
    padding: 20px 22px; display: flex; align-items: center; flex-wrap: wrap; gap: 14px;
  }
  .site-footer__left {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--ink-dim);
  }
  .sep { color: var(--ink-faint); }
  .site-footer__links { display: inline-flex; gap: 16px; margin-left: auto; }
  .site-footer__links a {
    color: var(--ink); text-decoration: underline;
    text-decoration-color: var(--line-strong);
    text-underline-offset: 3px;
    font-size: 14px;
    transition: text-decoration-color 0.15s var(--ease);
  }
  .site-footer__links a:hover { text-decoration-color: var(--ink); }

  .mono { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.02em; }

  /* ====== Article content ====== */
  .main--article h1, .main--article h2, .main--article h3, .main--article h4 {
    font-family: var(--font-serif);
    letter-spacing: -0.015em; line-height: 1.2;
    margin: 1.8em 0 0.5em;
    color: var(--ink);
  }
  .main--article h1 { font-size: clamp(2rem, 4.2vw, 2.8rem); margin-top: 0; font-weight: 600; }
  .main--article h2 {
    font-size: 1.5rem; font-weight: 600;
    padding-bottom: 0.2em; border-bottom: 1px solid var(--line);
  }
  .main--article h3 { font-size: 1.2rem; font-weight: 600; }
  .main--article p { margin: 0 0 1.1em; color: var(--ink); }
  .main--article a {
    color: var(--ink-link); text-decoration: underline;
    text-underline-offset: 3px; text-decoration-thickness: 1px;
    text-decoration-color: rgba(51, 90, 166, 0.35);
    transition: text-decoration-color 0.15s var(--ease);
  }
  .main--article a:hover { text-decoration-color: var(--ink-link); }
  .main--article ul, .main--article ol { padding-left: 1.3em; margin: 0 0 1.2em; }
  .main--article li { margin: 0.25em 0; }
  .main--article li::marker { color: var(--margin); }
  .main--article hr {
    border: none; border-top: 1px dashed var(--line-strong);
    margin: 2.5em auto; width: 60%;
  }
  .main--article code {
    font-family: var(--font-mono); font-size: 0.88em;
    background: var(--paper-2);
    padding: 0.1em 0.4em; border-radius: 4px;
    border: 1px solid var(--line);
  }
  .main--article pre {
    background: var(--paper-2);
    border: 1px solid var(--line);
    padding: 1rem 1.1rem; border-radius: var(--radius-sm); overflow-x: auto;
    font-family: var(--font-mono); font-size: 0.85em; line-height: 1.6;
  }
  .main--article pre code { background: transparent; border: none; padding: 0; }
  .main--article blockquote {
    border-left: 3px solid var(--margin);
    padding: 0.2em 1em; margin: 1.4em 0; color: var(--ink-dim);
    font-family: var(--font-serif); font-style: italic;
  }
  .main--article strong { font-weight: 600; }

  /* ====== Bilingual segments ====== */
  .lang-seg { transition: opacity 0.18s var(--ease), font-size 0.18s var(--ease); margin: 0.9em 0 0; }
  .lang-seg:first-child { margin-top: 0; }
  [lang='en'].lang-seg + [lang='ja'].lang-seg { margin-top: 0; }
  html[data-lang='en'] [lang='ja'].lang-seg { opacity: 0.4; font-size: 0.8em; }
  html[data-lang='ja'] [lang='en'].lang-seg { opacity: 0.4; font-size: 0.8em; }

  /* ====== Reveal ====== */
  [data-reveal] { opacity: 0; transform: translateY(8px); transition: opacity 0.5s var(--ease), transform 0.5s var(--ease); }
  [data-reveal].is-in { opacity: 1; transform: none; }
  [data-reveal][data-reveal-delay='1'] { transition-delay: 0.04s; }
  [data-reveal][data-reveal-delay='2'] { transition-delay: 0.1s; }
  [data-reveal][data-reveal-delay='3'] { transition-delay: 0.16s; }
  [data-reveal][data-reveal-delay='4'] { transition-delay: 0.22s; }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] { opacity: 1; transform: none; transition: none; }
    html { scroll-behavior: auto; }
  }
</style>
