---
import LangToggle from '../components/LangToggle.astro';
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <a href={import.meta.env.BASE_URL}>Blog</a>
      <LangToggle />
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  body { font-family: system-ui, sans-serif; max-width: 720px; margin: 2rem auto; padding: 0 1rem; line-height: 1.7; }
  header { margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; }
  header a { font-weight: bold; text-decoration: none; color: inherit; }
  pre { padding: 1rem; border-radius: 6px; overflow-x: auto; }

  .lang-seg { transition: opacity .15s ease; margin: 0; }
  html[data-lang="en"] [lang="ja"].lang-seg { opacity: .25; }
  html[data-lang="ja"] [lang="en"].lang-seg { opacity: .25; }
</style>
