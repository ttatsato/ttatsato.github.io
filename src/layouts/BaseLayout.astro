---
import LangToggle from '../components/LangToggle.astro';
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <a href={import.meta.env.BASE_URL}>Blog</a>
      <LangToggle />
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <a href="https://github.com/ttatsato" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 16 16" width="20" height="20" aria-hidden="true" fill="currentColor">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
      </a>
    </footer>
  </body>
</html>

<style is:global>
  body { font-family: system-ui, sans-serif; max-width: 720px; margin: 2rem auto; padding: 0 1rem; line-height: 1.7; }
  header { margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; }
  header a { font-weight: bold; text-decoration: none; color: inherit; }
  footer { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #eee; display: flex; justify-content: center; }
  footer a { color: #666; display: inline-flex; transition: color .15s ease; }
  footer a:hover { color: #000; }
  pre { padding: 1rem; border-radius: 6px; overflow-x: auto; }

  .lang-seg { transition: opacity .15s ease, font-size .15s ease; margin: 0.9em 0 0; }
  .lang-seg:first-child { margin-top: 0; }
  [lang="en"].lang-seg + [lang="ja"].lang-seg { margin-top: 0; }
  html[data-lang="en"] [lang="ja"].lang-seg { opacity: .35; font-size: .75em; }
  html[data-lang="ja"] [lang="en"].lang-seg { opacity: .35; font-size: .75em; }
</style>
