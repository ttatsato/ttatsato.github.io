---
import LangToggle from '../components/LangToggle.astro';
interface Props {
  title?: string;
  description?: string;
  variant?: 'home' | 'article' | 'wide';
  active?: 'home' | 'career' | 'scrap' | 'post';
}
const { title, description, variant = 'article', active } = Astro.props;
const base = import.meta.env.BASE_URL;
const SITE_SUFFIX = 'ttatsato Portfolio';
const fullTitle = title ? `${title} — ${SITE_SUFFIX}` : SITE_SUFFIX;

const navItems = [
  { id: 'home', label: 'Home', href: base },
  { id: 'career', label: 'Career', href: `${base}career/` },
  { id: 'scrap', label: 'Scrap', href: `${base}scrap/` },
];
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light" />
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Kalam:wght@300;400;700&family=Gloock&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <title>{fullTitle}</title>
  </head>
  <body data-variant={variant}>
    <div class="paper" aria-hidden="true"></div>

    <header class="site-header">
      <div class="site-header__inner">
        <a href={base} class="brand">
          ttatsato<span class="brand__dot">.</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          {navItems.map((n) => (
            <a href={n.href} class:list={['site-nav__link', active === n.id && 'is-active']}>
              {n.label}
            </a>
          ))}
        </nav>
        <LangToggle />
      </div>
    </header>

    <main class:list={['main', `main--${variant}`]}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__left">
          <span class="hand">— end of page —</span>
        </div>
        <div class="site-footer__mid">
          © {new Date().getFullYear()} ttatsato · Tokyo, JP
        </div>
        <div class="site-footer__links">
          <a href="https://github.com/ttatsato" target="_blank" rel="noopener noreferrer">github</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-in');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.08 }
        );
        const run = () =>
          document.querySelectorAll('[data-reveal]:not(.is-in)').forEach((el) => io.observe(el));
        run();
        document.addEventListener('astro:after-swap', run);
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Bullet Journal palette */
    --paper: #faf6ec;
    --paper-alt: #f3ecd9;
    --paper-dark: #ecdfbf;
    --paper-card: #fffdf7;
    --dot: #c8b99a;
    --ink: #2a2722;
    --ink-dim: rgba(42, 39, 34, 0.56);
    --ink-faint: rgba(42, 39, 34, 0.27);
    --line: rgba(42, 39, 34, 0.16);
    --line-strong: rgba(42, 39, 34, 0.32);

    --red: #b8452d;
    --teal: #2a6b6b;
    --navy: #1f3a68;
    --yellow: #e8c547;
    --olive: #7c7a3e;

    --hl-yellow: rgba(255, 230, 80, 0.55);
    --hl-pink: rgba(255, 170, 170, 0.55);
    --hl-green: rgba(160, 230, 170, 0.55);
    --hl-blue: rgba(150, 210, 240, 0.55);

    --radius: 0; /* mostly straight edges in BuJo */
    --maxw: 1180px;
    --maxw-read: 760px;

    --font-marker: 'Gloock', 'Caveat', serif;
    --font-hand: 'Caveat', cursive;
    --font-note: 'Kalam', 'Caveat', cursive;
    --font-mono: 'JetBrains Mono', ui-monospace, Menlo, monospace;

    --ease: cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-note);
    font-size: 17px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
    min-height: 100vh;
  }

  ::selection { background: var(--hl-yellow); color: var(--ink); }

  /* Dot grid paper backdrop */
  .paper {
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background-image: radial-gradient(var(--dot) 1.2px, transparent 1.6px);
    background-size: 22px 22px;
    background-position: 11px 11px;
    opacity: 0.55;
  }

  /* ====== Header ====== */
  .site-header {
    position: sticky; top: 0; z-index: 40;
    background: rgba(250, 246, 236, 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-bottom: 2.5px solid var(--ink);
  }
  .site-header__inner {
    max-width: var(--maxw); margin: 0 auto;
    padding: 10px 20px;
    display: flex; align-items: center; gap: 18px;
  }
  .brand {
    font-family: var(--font-marker);
    font-size: 22px; color: var(--ink);
    text-decoration: none; letter-spacing: -0.01em;
    padding-right: 12px;
    border-right: 1.5px solid rgba(42, 39, 34, 0.26);
    margin-right: 6px;
  }
  .brand__dot { color: var(--red); }
  .site-nav { display: flex; gap: 2px; align-items: center; }
  .site-nav__link {
    font-family: var(--font-marker);
    font-size: 16px; color: var(--ink);
    text-decoration: none;
    padding: 4px 14px;
    letter-spacing: 0.01em;
    border: 2px solid transparent;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .site-nav__link:hover { background: rgba(42, 39, 34, 0.08); }
  .site-nav__link.is-active {
    background: var(--ink);
    color: var(--paper);
  }

  /* right-align Lang toggle */
  .lang-toggle { margin-left: auto; }

  @media (max-width: 720px) {
    .site-nav { gap: 0; }
    .site-nav__link { font-size: 14px; padding: 4px 8px; }
    .brand { font-size: 18px; }
  }

  /* ====== Main ====== */
  .main { position: relative; z-index: 1; }
  .main--article {
    max-width: var(--maxw-read); margin: 0 auto; padding: 40px 24px 72px;
  }
  .main--home, .main--wide { padding-bottom: 64px; }

  /* ====== Footer ====== */
  .site-footer {
    position: relative; z-index: 1;
    border-top: 2.5px solid var(--ink);
    margin-top: 64px;
    background: var(--paper-alt);
  }
  .site-footer__inner {
    max-width: var(--maxw); margin: 0 auto;
    padding: 20px 24px; display: flex; align-items: center; flex-wrap: wrap; gap: 14px;
    font-family: var(--font-hand); font-size: 18px; color: var(--ink-dim);
  }
  .site-footer__mid {
    margin-left: auto; margin-right: auto;
    font-family: var(--font-mono); font-size: 12px;
  }
  .site-footer__links { display: inline-flex; gap: 14px; }
  .site-footer__links a {
    color: var(--ink); font-family: var(--font-marker); font-size: 16px;
    text-decoration: none;
    border-bottom: 1.5px solid var(--ink);
    padding-bottom: 1px;
  }
  .site-footer__links a:hover { color: var(--red); border-color: var(--red); }

  .hand { font-family: var(--font-hand); }
  .marker { font-family: var(--font-marker); }
  .note { font-family: var(--font-note); }
  .mono { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.02em; }

  /* ====== Article content (posts, scraps) ====== */
  .main--article h1, .main--article h2, .main--article h3, .main--article h4 {
    font-family: var(--font-marker);
    letter-spacing: -0.015em; line-height: 1.15;
    margin: 1.6em 0 0.4em;
    color: var(--ink);
  }
  .main--article h1 { font-size: clamp(2rem, 4.6vw, 3rem); font-weight: 800; margin-top: 0; }
  .main--article h2 {
    font-size: 1.6rem; font-weight: 700;
    padding-bottom: 0.2em; border-bottom: 1.5px solid var(--ink);
  }
  .main--article h3 { font-size: 1.25rem; font-weight: 700; color: var(--teal); }
  .main--article p { margin: 0 0 1em; color: var(--ink); }
  .main--article a {
    color: var(--red); text-decoration: underline;
    text-underline-offset: 3px; text-decoration-thickness: 1.5px;
    text-decoration-style: dashed;
  }
  .main--article a:hover { background: rgba(184, 69, 45, 0.08); }
  .main--article ul, .main--article ol { padding-left: 1.3em; margin: 0 0 1em; }
  .main--article li { margin: 0.25em 0; }
  .main--article li::marker { color: var(--red); }
  .main--article hr {
    border: none; border-top: 2px dashed var(--ink);
    margin: 2em auto; width: 60%; opacity: 0.4;
  }
  .main--article code {
    font-family: var(--font-mono); font-size: 0.88em;
    background: var(--paper-alt);
    padding: 0.1em 0.4em;
    border: 1px solid var(--line);
  }
  .main--article pre {
    background: var(--paper-card);
    border: 2px solid var(--ink);
    padding: 1rem 1.1rem; overflow-x: auto;
    font-family: var(--font-mono); font-size: 0.85em; line-height: 1.6;
    box-shadow: 4px 4px 0 var(--ink);
  }
  .main--article pre code { background: transparent; border: none; padding: 0; }
  .main--article blockquote {
    font-family: var(--font-marker);
    font-size: 1.4rem; line-height: 1.3;
    border-left: 4px solid var(--red);
    padding: 0.2em 1em; margin: 1.4em 0;
    color: var(--ink);
  }
  .main--article strong { font-weight: 700; }

  /* ====== Bilingual segments ====== */
  .lang-seg { transition: opacity 0.18s var(--ease), font-size 0.18s var(--ease); margin: 0.9em 0 0; }
  .lang-seg:first-child { margin-top: 0; }
  [lang='en'].lang-seg + [lang='ja'].lang-seg { margin-top: 0; }
  html[data-lang='en'] [lang='ja'].lang-seg { opacity: 0.4; font-size: 0.82em; }
  html[data-lang='ja'] [lang='en'].lang-seg { opacity: 0.4; font-size: 0.82em; }

  /* ====== Reveal ====== */
  [data-reveal] { opacity: 0; transform: translateY(8px); transition: opacity 0.5s var(--ease), transform 0.5s var(--ease); }
  [data-reveal].is-in { opacity: 1; transform: none; }
  [data-reveal][data-reveal-delay='1'] { transition-delay: 0.04s; }
  [data-reveal][data-reveal-delay='2'] { transition-delay: 0.1s; }
  [data-reveal][data-reveal-delay='3'] { transition-delay: 0.16s; }
  [data-reveal][data-reveal-delay='4'] { transition-delay: 0.22s; }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] { opacity: 1; transform: none; transition: none; }
    html { scroll-behavior: auto; }
  }
</style>
